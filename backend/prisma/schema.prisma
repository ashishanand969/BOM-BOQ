// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  avatar    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  projects  Project[]
  boqItems  BOQItem[]
  bomItems  BOMItem[]

  @@map("users")
}

model Project {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  boqItems   BOQItem[]
  bomItems   BOMItem[]

  @@index([userId])
  @@map("projects")
}

model BOQItem {
  id           String     @id @default(cuid())
  projectId    String
  userId       String
  itemName     String
  description  String?
  quantity     Decimal    @db.Decimal(12, 2)
  unit         String
  unitRate     Decimal    @db.Decimal(12, 2)
  gstPercent   Decimal    @default(18) @db.Decimal(5, 2)
  subtotal     Decimal    @db.Decimal(14, 2)
  gstAmount    Decimal    @db.Decimal(14, 2)
  total        Decimal    @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("boq_items")
}

model BOMItem {
  id             String     @id @default(cuid())
  projectId      String
  userId         String
  componentName  String
  description    String?
  quantity       Decimal    @db.Decimal(12, 2)
  costPerUnit    Decimal    @db.Decimal(12, 2)
  supplier       String?
  category       String?
  parentItemId   String?
  total          Decimal    @db.Decimal(14, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentItem     BOMItem?   @relation("BOMItemChildren", fields: [parentItemId], references: [id], onDelete: SetNull)
  childItems     BOMItem[]  @relation("BOMItemChildren")

  @@index([projectId])
  @@index([userId])
  @@index([parentItemId])
  @@map("bom_items")
}
